# Copy this file to .env (gitignored) for local development.
# In GitHub Actions, configure these as repository Secrets and Variables.

# Required: Alpaca API credentials.
# Generate at https://app.alpaca.markets/paper/dashboard/overview
# (use the "Paper Trading" key set, NOT live trading).
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here

# Safety: paper mode by default. Set to "false" ONLY if you understand
# the consequences. The Broker class checks this on every run.
ALPACA_PAPER=true

# Kill switch: set to "true" to halt all trading without a code push.
# In GitHub Actions, configure this as a repo Variable so you can flip
# it from the Actions UI.
KILL_SWITCH=false
